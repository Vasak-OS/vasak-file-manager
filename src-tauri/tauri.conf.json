{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vasak-file-manager",
  "version": "0.1.0",
  "identifier": "ar.net.vasak.vasak-file-manager",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vasak File Manager",
        "width": 1280,
        "height": 720,
        "minWidth": 750,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "deb",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      },
      "deb": {
        "depends": [
          "vasak-desktop-settings",
          "libcairo2",
          "desktop-file-utils",
          "libgdk-pixbuf-2.0-0",
          "libglib2.0-0t64",
          "libgtk-3-0t64",
          "hicolor-icon-theme",
          "libsoup2.4-1",
          "libsoup-3.0-0",
          "libpango-1.0-0",
          "libwebkit2gtk-4.1-0",
          "librsvg2-devel",
          "gstreamer1.0-plugins-base",
          "gstreamer1.0-plugins-good",
          "gstreamer1.0-plugins-bad-free",
          "gstreamer1-libav"
        ],
        "files": {}
      }
    },
    "icon": [
      "icons/folder.svg"
    ]
  }
}